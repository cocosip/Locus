{
  "Locus": {
    "MetadataDirectory": "./locus-metadata",
    "QuotaDirectory": "./locus-quota",
    "FileWatcherConfigurationDirectory": "./locus-watchers",
    "AutoCreateTenants": true,
    "DefaultTenantQuota": 0,
    "MetadataRepository": {
      "EnableBackgroundPersistence": true,
      "MaxQueueSize": 100000,
      "DrainBatchSize": 2000,
      "SoftMergeThresholdPercent": 90,
      "StartupLoadBatchSize": 2000,
      "ShutdownDrainTimeoutSeconds": 30,
      "PersistenceIntervalSeconds": 2
    },
    "StoragePool": {
      "CompletionGuardStripeCount": 256
    },
    "EnableDatabaseHealthCheck": true,
    "AutoRecoverCorruptedDatabasesOnStartup": true,
    "FailFastOnStartupRecoveryFailure": false,
    "Sqlite": {
      "JournalMode": "WAL",
      "SynchronousMode": "NORMAL",
      "CacheSizeKb": -4000,
      "BusyTimeoutMs": 5000,
      "CheckpointAfterBatch": true
    },
    "RetryPolicy": {
      "MaxRetryCount": 3,
      "InitialRetryDelay": "00:00:05",
      "UseExponentialBackoff": true,
      "MaxRetryDelay": "00:05:00"
    },
    "Volumes": [
      {
        "VolumeId": "vol-001",
        "MountPath": "./storage/volume-1",
        "VolumeType": "LocalFileSystem",
        "ShardingDepth": 2,
        "InitialDelayMs": 0,
        "HealthCheckDelayMs": 500,
        "WriteBufferSize": 131072,
        "CopyBufferSize": 81920,
        "ForceFlushAfterWrite": false
      },
      {
        "VolumeId": "vol-002",
        "MountPath": "./storage/volume-2",
        "VolumeType": "LocalFileSystem",
        "ShardingDepth": 2,
        "InitialDelayMs": 0,
        "HealthCheckDelayMs": 500,
        "WriteBufferSize": 131072,
        "CopyBufferSize": 81920,
        "ForceFlushAfterWrite": false
      }
    ],
    "Tenants": [
      {
        "TenantId": "tenant-001",
        "Enabled": true,
        "Quota": 10000
      },
      {
        "TenantId": "tenant-002",
        "Enabled": true,
        "Quota": null
      },
      {
        "TenantId": "tenant-disabled",
        "Enabled": false,
        "Quota": null
      }
    ],
    "FileWatchers": [
      {
        "WatcherId": "watcher-vip-tenant-001",
        "TenantId": "tenant-001",
        "MultiTenantMode": false,
        "AutoCreateTenantDirectories": false,
        "AutoCreateTenantDirectoriesCacheTtl": "00:01:00",
        "WatchPath": "./watch/vip/tenant-001",
        "Enabled": true,
        "IncludeSubdirectories": true,
        "FilePatterns": [
          "*.pdf",
          "*.docx",
          "*.xlsx"
        ],
        "PostImportAction": "Delete",
        "PollingInterval": "00:00:10",
        "MaxFileSizeBytes": 104857600,
        "MinFileAge": "00:00:03",
        "FileStabilityCheckDelay": "00:00:00:100",
        "SkipStabilityCheckAfterAge": "00:01:00",
        "MaxConcurrentImports": 16,
        "EnableImportedFilesPruneThrottle": true,
        "ImportedFilesPruneInterval": "00:05:00",
        "EnableImportedFilesHistoryFlushDebounce": true,
        "ImportedFilesHistoryFlushInterval": "00:00:02"
      },
      {
        "WatcherId": "watcher-all-regular-tenants",
        "TenantId": "",
        "MultiTenantMode": true,
        "AutoCreateTenantDirectories": true,
        "AutoCreateTenantDirectoriesCacheTtl": "00:01:00",
        "WatchPath": "./watch/shared",
        "Enabled": true,
        "IncludeSubdirectories": true,
        "FilePatterns": [
          "*.*"
        ],
        "PostImportAction": "Delete",
        "PollingInterval": "00:00:30",
        "MaxFileSizeBytes": 0,
        "MinFileAge": "00:00:05",
        "MaxConcurrentImports": 8,
        "EnableImportedFilesPruneThrottle": true,
        "ImportedFilesPruneInterval": "00:05:00",
        "EnableImportedFilesHistoryFlushDebounce": true,
        "ImportedFilesHistoryFlushInterval": "00:00:02"
      }
    ],
    "EnableOrphanRecovery": true,
    "OrphanRecoveryOptions": {
      "RecoveryInterval": "00:30:00",
      "InitialDelay": "00:00:10"
    },
    "EnableBackgroundCleanup": true,
    "CleanupOptions": {
      "CleanupInterval": "01:00:00",
      "InitialDelay": "00:00:10",
      "CleanupTimedOutFiles": true,
      "ProcessingTimeout": "00:30:00",
      "CleanupPermanentlyFailedFiles": true,
      "CleanupInvalidDatabaseBackups": true,
      "FailedFileRetentionPeriod": "7.00:00:00",
      "CleanupCompletedRecords": false,
      "CompletedRecordRetentionPeriod": "30.00:00:00",
      "OptimizeDatabases": true,
      "DatabaseOptimizationInterval": "1.00:00:00",
      "CleanupBatchSizePerTenant": 500,
      "OrphanRebuildLookupCacheSize": 8192,
      "DatabaseOptimizationTenantBatchSize": 10,
      "DatabaseOptimizationPauseBetweenBatches": "00:00:00.200"
    }
  }
}
